__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# per-job uploaded archives, extracted trees, and analysis output - can
# contain sensitive hostnames/IPs/config data and shouldn't be committed
backend/data/

# auto-generated self-signed TLS cert/key for --https - machine-specific
# and the private key should never be committed even though it's
# self-signed and low-value
/certs/

# analyzer CLI-style output directories, if ever generated locally
*_analysis/
extraction_skipped.json

# local-only AI settings someone might export/dump for debugging
*.env
.env.local

.DS_Store
Thumbs.db
